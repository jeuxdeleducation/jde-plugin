# Fichiers exclus des archives ZIP générées par GitHub (releases automatiques).
# Le workflow release.yml construit son propre ZIP, mais on garde cette config
# au cas où quelqu'un téléchargerait l'archive « Source code (zip) » de GitHub.

/.github           export-ignore
/tests             export-ignore
/.editorconfig     export-ignore
/.gitattributes    export-ignore
/.gitignore        export-ignore
/.distignore       export-ignore
/phpcs.xml.dist    export-ignore
/phpunit.xml.dist  export-ignore
/package.json      export-ignore
/package-lock.json export-ignore
/composer.json     export-ignore
/composer.lock     export-ignore
/CLAUDE.md         export-ignore

# Normaliser les fins de ligne
* text=auto eol=lf
*.png binary
*.jpg binary
*.gif binary
*.ico binary
